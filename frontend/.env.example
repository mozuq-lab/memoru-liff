# API Base URL
VITE_API_BASE_URL=https://api.example.com

# LIFF ID (from LINE Developers Console)
VITE_LIFF_ID=1234567890-abcdefgh

# === OIDC Provider Configuration ===
# Keycloak の場合:
VITE_OIDC_AUTHORITY=https://keycloak.example.com/realms/memoru
VITE_OIDC_CLIENT_ID=liff-client

# Cognito の場合:
# VITE_OIDC_AUTHORITY=https://cognito-idp.ap-northeast-1.amazonaws.com/ap-northeast-1_XXXXXXXXX
# VITE_OIDC_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# === AI生成タイムアウト (ms, 任意) ===
# 未設定なら既定値 (テキスト 30000 / URL 90000)。低速プロバイダ(ローカルLLM等)利用時に延長する。
# VITE_MAX_GENERATION_TIME=180000
# VITE_MAX_URL_GENERATION_TIME=180000
